rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isUnverifiedSignedIn() { return request.auth != null; } // allow google signin users

    // Users
    function isValidUserCreate(data) {
      return data.keys().hasAll(['uid', 'createdAt']) &&
        data.keys().size() <= 4 &&
        data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
        data.createdAt == request.time &&
        (data.get('theme', '') is string) &&
        (data.get('completedBingos', 0) is number);
    }
    
    // Updates to user
    function isUserUpdate(data, old) {
      return data.uid == old.uid && data.createdAt == old.createdAt &&
        (data.get('theme', '') is string && data.get('theme', '').size() <= 50) &&
        (data.get('completedBingos', 0) is number);
    }

    // Saved Grids
    function isValidSavedGridCreate(data) {
      return data.keys().hasAll(['userId', 'mode', 'items', 'createdAt']) &&
        data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
        data.mode is string && data.mode.size() <= 50 &&
        (data.get('title', '') is string && data.get('title', '').size() <= 200) &&
        data.items is list && data.items.size() <= 30 &&
        data.createdAt == request.time;
    }

    // Diary
    function isValidVibeDiaryEntryCreate(data) {
      return data.keys().hasAll(['userId', 'mode', 'items', 'date', 'createdAt']) &&
        data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
        data.mode is string && data.mode.size() <= 50 &&
        data.items is list && data.items.size() <= 30 &&
        data.date is string && data.date.size() <= 30 &&
        data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isUnverifiedSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow create: if isUnverifiedSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUserCreate(incoming());
      allow update: if isUnverifiedSignedIn() && isValidId(userId) && userId == request.auth.uid && isUserUpdate(incoming(), existing()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'completedBingos']);
    }

    match /saved_grids/{gridId} {
      allow get: if isUnverifiedSignedIn() && isValidId(gridId) && existing().userId == request.auth.uid;
      allow list: if isUnverifiedSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isUnverifiedSignedIn() && isValidId(gridId) && isValidSavedGridCreate(incoming());
      allow update: if isUnverifiedSignedIn() && isValidId(gridId) && existing().userId == request.auth.uid &&
        incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
        incoming().mode is string && incoming().mode.size() <= 50 &&
        (incoming().get('title', '') is string && incoming().get('title', '').size() <= 200) &&
        incoming().items is list && incoming().items.size() <= 30 &&
        incoming().diff(existing()).affectedKeys().hasOnly(['items', 'mode', 'title']);
      allow delete: if isUnverifiedSignedIn() && isValidId(gridId) && existing().userId == request.auth.uid;
    }

    match /vibe_diary/{diaryId} {
      allow get: if isUnverifiedSignedIn() && isValidId(diaryId) && existing().userId == request.auth.uid;
      allow list: if isUnverifiedSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isUnverifiedSignedIn() && isValidId(diaryId) && isValidVibeDiaryEntryCreate(incoming());
      allow delete: if isUnverifiedSignedIn() && isValidId(diaryId) && existing().userId == request.auth.uid;
      // No update allowed for diary entries
    }
  }
}
